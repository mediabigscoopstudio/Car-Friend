# Copy to .env (which is gitignored) and fill in real values. Never commit .env.
# This file holds KEY NAMES ONLY — no real values, ever.

# ── Core Django ──
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=
MAINTENANCE_MODE=

# ── Database (PostgreSQL — engine/host stay on the VPS) ──
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ── AWS S3 (media files only; static stays local) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# ── Google OAuth (allauth) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Digio KYC ──
DIGIO_BASE_URL=
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# ── Surepass RC lookup (server-side only) ──
SUREPASS_TOKEN=
# SUREPASS_BASE_URL=

# ── Messaging / push ──
FAST2SMS_API_KEY=
FCM_SERVER_KEY=
WA_TOKEN=
WA_PHONE_ID=
SMS_API_KEY=
SMS_SENDER=

# ── Hosts ──
PARENT_HOST=
