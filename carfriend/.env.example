# Copy to .env (which is gitignored) and fill in real values. Never commit .env.

# Surepass RC lookup API — bearer token (sandbox).
# Used only server-side by www/services.py; never exposed to templates/JS.
SUREPASS_TOKEN=

# Optional: override the Surepass base URL (defaults to the sandbox).
# SUREPASS_BASE_URL=https://sandbox.surepass.app
